  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debugger: Fastapi",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": ["app.main:app", "--reload"],
      "jinja": false,
      "serverReadyAction": {
        "pattern": "running on http://127.0.0.1:([0-9]+)",
        "uriFormat": "http://localhost:%s",
        "action": "openExternally"
      },
      
    }
  ]
}